# ─────────────────────────────────────────────────────────────────
# Datadog – copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────

# Mandatory: your Datadog API key (https://app.datadoghq.com/organization-settings/api-keys)
DD_API_KEY=your_datadog_api_key_here

# Optional: Datadog site region (default: datadoghq.com)
#   US1  → datadoghq.com
#   EU1  → datadoghq.eu
#   US3  → us3.datadoghq.com
#   US5  → us5.datadoghq.com
#   AP1  → ap1.datadoghq.com
DD_SITE=datadoghq.com

# Environment name shown on all Datadog pages (Unified Service Tagging)
DD_ENV=local

